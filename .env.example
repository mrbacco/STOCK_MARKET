# Copy to .env. Use a long generated password outside local development.
POSTGRES_DB=stock_market
POSTGRES_USER=stock_market
POSTGRES_PASSWORD=change-me
REDIS_MAXMEMORY=1gb

# Common variants warmed by analytics_worker.py.
ANALYTICS_PERIODS=1y
ANALYTICS_HORIZONS=1,3,5
ANALYTICS_INTERVAL_SECONDS=900

# Public-provider protection shared by replicas and workers.
PROVIDER_MAX_ATTEMPTS=3
PROVIDER_BACKOFF_SECONDS=0.5
YAHOO_MIN_INTERVAL_SECONDS=0.25
NEWS_MIN_INTERVAL_SECONDS=0.20

# Optional locally: market_data.py already chooses data/yfinance-cache.
# Docker Compose defaults this to /app/data/yfinance-cache.
# YFINANCE_CACHE_DIR=C:\path\to\a\writable\yfinance-cache
