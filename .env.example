# Copy to .env. Use a long generated password outside local development.
POSTGRES_DB=stock_market
POSTGRES_USER=stock_market
POSTGRES_PASSWORD=change-me
REDIS_MAXMEMORY=1gb

# Common variants warmed by analytics_worker.py.
ANALYTICS_PERIODS=1y
ANALYTICS_HORIZONS=1,3,5
ANALYTICS_INTERVAL_SECONDS=900

# Public-provider protection shared by replicas and workers.
PROVIDER_MAX_ATTEMPTS=3
PROVIDER_BACKOFF_SECONDS=0.5
YAHOO_MIN_INTERVAL_SECONDS=0.25
NEWS_MIN_INTERVAL_SECONDS=0.20

# Market data provider. Keep yfinance for local development. To evaluate
# Marketstack EOD, set the provider and put your own key in the local .env file.
# Never commit an actual API key.
MARKET_DATA_PROVIDER=yfinance
# MARKETSTACK_API_KEY=
# MARKETSTACK_BASE_URL=https://api.marketstack.com/v2
# MARKETSTACK_SYMBOL_MAP={"ENI.MI":"provider-confirmed-symbol"}
#
# Set this true only after the vendor confirms rights for the exact exchanges,
# external customer display, retained history, and derived forecast outputs.
MARKET_DATA_LICENSE_CONFIRMED=false

# Free real-time mode uses bounded REST polling rather than a paid streaming
# feed. Values are clamped to 30-300 seconds; 60 seconds is recommended.
LIVE_CHART_REFRESH_SECONDS=60

# Optional locally: market_data.py already chooses data/yfinance-cache.
# Docker Compose defaults this to /app/data/yfinance-cache.
# YFINANCE_CACHE_DIR=C:\path\to\a\writable\yfinance-cache
